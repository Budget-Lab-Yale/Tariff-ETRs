// =============================================================================
// PROPOSED ARCHITECTURE: Single Repo, Parameterized Engine, Config/Data Split
// =============================================================================
// Render: dot -Tpng docs/architecture_proposed.dot -o docs/architecture_proposed.png -Gdpi=150
//     or: dot -Tsvg docs/architecture_proposed.dot -o docs/architecture_proposed.svg

digraph proposed {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=12, margin="0.2,0.1"];
    edge [fontname="Helvetica", fontsize=10];
    label=<<B>Proposed Architecture</B><BR/>Single repo, parameterized engine, config/data separation>;
    labelloc=t;
    fontsize=18;
    nodesep=0.6;
    ranksep=0.55;

    // =====================================================================
    // ROW 1: Two sources of config
    // =====================================================================

    // Left: HTS preprocessing
    subgraph cluster_preprocess {
        label=<<B>Preprocessing</B>  (cached; re-run with --rebuild-configs)>;
        style=filled; fillcolor="#FEF9E7"; color="#F39C12";
        fontsize=12; fontcolor="#E67E22";

        hts [label="HTS JSON\nArchives", shape=cylinder, style=filled, fillcolor="#E8E8E8"];
        parser [label="HTS Parser\n(Ch99 footnotes,\nrate extraction,\nprogram classification)", shape=box, style="filled,rounded", fillcolor=white];
    }

    // Right: User input
    subgraph cluster_user {
        label=<<B>User Input</B>>;
        style=filled; fillcolor="#FDEDEC"; color="#E74C3C";
        fontsize=12; fontcolor="#C0392B";

        scenario_yaml [
            label=<<B>scenario.yaml</B><BR/><BR/>baseline: '2025-01-01'<BR/>counterfactual: historical<BR/>reforms:<BR/>  - date: '2026-07-20'<BR/>    from: '2026-02-20'<BR/>    apply: reforms/s122_expired>,
            shape=note, style=filled, fillcolor=white, fontsize=10
        ];
        reform_yaml [
            label=<<B>reform.yaml</B><BR/><BR/>rates:<BR/>  s122: 0<BR/>params:<BR/>  ...<BR/>stacking:<BR/>  ...>,
            shape=note, style=filled, fillcolor=white, fontsize=10
        ];
    }

    // =====================================================================
    // ROW 2: Config (generated by preprocessing, consumed by scenario builder)
    // =====================================================================
    subgraph cluster_config {
        label=<<B>config/historical/{date}/</B>  (one folder per revision -- generated by parser, human-readable)>;
        style=filled; fillcolor="#EAFAF1"; color="#27AE60";
        fontsize=12; fontcolor="#27AE60";

        rates [
            label=<<B>rates.csv.gz</B><BR/>Statutory per-authority rates<BR/>hs10 x country (sparse)>,
            shape=note, style=filled, fillcolor=white, fontsize=10
        ];
        params [
            label=<<B>params.yaml</B><BR/>Adjustment parameters<BR/>(rebate, USMCA flags,<BR/>metal method, floors)>,
            shape=note, style=filled, fillcolor=white, fontsize=10
        ];
        stacking_rules [
            label=<<B>stacking.yaml</B><BR/>Authority interaction rules<BR/>(exclusive, cumulative,<BR/>country overrides)>,
            shape=note, style=filled, fillcolor=white, fontsize=10
        ];
    }

    // =====================================================================
    // ROW 3: Scenario builder (assembles config for each date)
    // =====================================================================
    subgraph cluster_builder {
        label=<<B>Scenario Builder</B>  (assembles a policy state for each date in the timeline)>;
        style=filled; fillcolor="#F5EEF8"; color="#8E44AD";
        fontsize=12; fontcolor="#8E44AD";

        resolve [label="Resolve Timeline\n(all revision dates\nbetween baseline\nand horizon)", shape=box, style="filled,rounded", fillcolor=white];
        branch [label="Historical\nor reformed?", shape=diamond, style=filled, fillcolor=white];
        hist_path [
            label=<<B>Historical</B><BR/>(39/40 dates)<BR/><BR/>Use config folder as-is>,
            shape=box, style="filled,rounded", fillcolor="#D5F5E3"
        ];
        reform_path [
            label=<<B>Reformed</B><BR/>(1/40 dates)<BR/><BR/>Config folder +<BR/>reform overlay>,
            shape=box, style="filled,rounded", fillcolor="#FCF3CF"
        ];
        assembled [label="Assembled Config\nfor this date\n(rates + params +\nstacking rules)", shape=parallelogram, style=filled, fillcolor="#E8DAEF"];
    }

    // =====================================================================
    // ROW 4: Data (loaded once, separate from config)
    // =====================================================================
    subgraph cluster_data {
        label=<<B>data/</B>  (loaded once, not config -- describes the world, not policy)>;
        style=filled; fillcolor="#EBF5FB"; color="#2980B9";
        fontsize=12; fontcolor="#2980B9";

        imports [label="Import Weights\n(Census)", shape=cylinder, style=filled, fillcolor="#D4E6F1"];
        metal [label="Metal Content\n(BEA I-O)", shape=cylinder, style=filled, fillcolor="#D4E6F1"];
        usmca [label="USMCA Shares\n(DataWeb)", shape=cylinder, style=filled, fillcolor="#D4E6F1"];
        mfn_exempt [label="MFN Exemptions\n(Census)", shape=cylinder, style=filled, fillcolor="#D4E6F1"];
    }

    // =====================================================================
    // ROW 5: Engine (config + data → final rates)
    // =====================================================================
    subgraph cluster_engine {
        label=<<B>Engine</B>  (pure functions, parameterized by YAML, no hardcoded authority names)>;
        style=filled; fillcolor="#F4ECF7"; color="#8E44AD";
        fontsize=12; fontcolor="#8E44AD";

        engine [
            label=<<B>compute_final_rates(config, data)</B><BR/><BR/>1. Auto rebate  2. USMCA exemptions  3. MFN exemptions<BR/>4. Target-total floors  5. Metal content scaling<BR/>6. <B>Generic stacking</B> (driven by stacking.yaml)>,
            shape=box, style="filled,rounded", fillcolor="#E8DAEF", fontsize=11
        ];
    }

    // Cache (lives alongside config, populated by preprocessing OR scenario runner)
    cache [
        label=<<B>.cache/final_rates.rds</B><BR/>(pre-computed by preprocessing;<BR/>skips engine for historical dates)>,
        shape=note, style=filled, fillcolor="#FCF3CF", fontsize=10
    ];

    // =====================================================================
    // ROW 6: Delta computation + outputs
    // =====================================================================
    final_rates [label="final_rate\nper hs10 x country\n(for this date)", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];

    delta [label="Compute Delta\n(counterfactual - baseline)\nweighted by imports", shape=box, style="filled,rounded", fillcolor=white];

    repeat [
        label=<<I>repeat for each date in timeline</I>>,
        shape=plaintext, fontsize=10, fontcolor="#8E44AD"
    ];

    subgraph cluster_output {
        label=<<B>output/scenarios/{name}/</B>>;
        style=filled; fillcolor="#EAFAF1"; color="#27AE60";
        fontsize=12; fontcolor="#27AE60";

        out [label="Deltas + Levels\nby Country, HTS2\n(model-agnostic)", shape=note, style=filled, fillcolor=white];
    }

    downstream [
        label="Downstream Consumer\n(separate repo)\n\nGTAP crosswalk,\npartner aggregation,\nshock formatting",
        shape=box, style="filled,rounded,dashed", fillcolor="#F2F3F4", color="#AAAAAA", fontcolor="#666666"
    ];

    // =====================================================================
    // EDGES: Preprocessing → Config
    // =====================================================================
    hts -> parser;
    parser -> rates [label="  generates  ", color="#27AE60", fontcolor="#27AE60"];
    parser -> params [color="#27AE60"];
    parser -> stacking_rules [color="#27AE60"];

    // =====================================================================
    // EDGES: Config + User Input → Scenario Builder
    // =====================================================================
    rates -> resolve [color="#27AE60", style=dashed];
    params -> resolve [color="#27AE60", style=dashed];
    stacking_rules -> resolve [color="#27AE60", style=dashed];

    scenario_yaml -> resolve [color="#C0392B"];
    reform_yaml -> reform_path [color="#C0392B", style=dashed];

    resolve -> branch;
    branch -> hist_path [label="  cached  ", color="#27AE60", fontcolor="#27AE60"];
    branch -> reform_path [label="  modified  ", color="#E67E22", fontcolor="#E67E22"];
    hist_path -> assembled;
    reform_path -> assembled;

    // =====================================================================
    // EDGES: Assembled Config + Data → Engine → Output
    // =====================================================================
    assembled -> engine [label="  config  ", color="#8E44AD", fontcolor="#8E44AD"];
    metal -> engine [style=dashed, color="#2980B9", label="  data  "];
    usmca -> engine [style=dashed, color="#2980B9"];
    mfn_exempt -> engine [style=dashed, color="#2980B9"];

    // Cache shortcut: preprocessing runs engine and caches result
    // Historical path can skip engine entirely
    hist_path -> cache [style=dashed, color="#27AE60", label="  read\n  cache  "];
    cache -> final_rates [style=dashed, color="#27AE60", label="  skip\n  engine  "];
    parser -> cache [
        style=dashed, color="#F39C12",
        label="  preprocessing\n  populates cache  "
    ];

    engine -> final_rates [color="#8E44AD"];

    imports -> delta [style=dashed, color="#2980B9", label="  data  "];
    final_rates -> delta;
    delta -> out;
    out -> downstream [style=dashed, color="#AAAAAA"];

    { rank=same; repeat; delta; }

    // =====================================================================
    // LEGEND
    // =====================================================================
    legend [
        shape=plaintext,
        label=<
            <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#FEF9E7">Yellow</TD><TD ALIGN="LEFT">PREPROCESSING (HTS parsing, cached, run once per revision)</TD></TR>
            <TR><TD BGCOLOR="#FDEDEC">Red</TD><TD ALIGN="LEFT">USER INPUT (scenario definition, reform overlays)</TD></TR>
            <TR><TD BGCOLOR="#EAFAF1">Green</TD><TD ALIGN="LEFT">CONFIG (per-revision policy: rates, params, stacking rules)</TD></TR>
            <TR><TD BGCOLOR="#F4ECF7">Purple</TD><TD ALIGN="LEFT">SCENARIO BUILDER + ENGINE (assemble config, compute rates)</TD></TR>
            <TR><TD BGCOLOR="#EBF5FB">Blue</TD><TD ALIGN="LEFT">DATA (external, loaded once: imports, metal, USMCA, MFN)</TD></TR>
            <TR><TD COLSPAN="2" ALIGN="LEFT"><B>Runtime: ~30 sec</B> for 40-date scenario (39 cache reads + 1 engine run)</TD></TR>
            </TABLE>
        >
    ];
}
